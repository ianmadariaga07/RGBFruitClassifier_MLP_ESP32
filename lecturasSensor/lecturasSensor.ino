#include <Wire.h>
#include "Adafruit_TCS34725.h"
Adafruit_TCS34725 tcs = Adafruit_TCS34725(TCS34725_INTEGRATIONTIME_50MS, TCS34725_GAIN_1X);

void setup(){
  Serial.begin(115200);
  if (tcs.begin()) {
    Serial.println("Sensor encontrado");
  }else{
    Serial.println("No se encuentra el sensor TCS34725");
    while (1);
  }
}

void loop(){
  float red, green, blue;
  tcs.getRGB(&red, &green, &blue);
  int r = (int)red;
  int g = (int)green;
  int b = (int)blue;

  Serial.print(r);
  Serial.print(",");
  Serial.print(g);
  Serial.print(",");
  Serial.println(b);
  delay(100);
}
